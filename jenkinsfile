pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/hs0761725-cpu/cicd-demo.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t cicd-demo .'
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                docker rm -f cicd-demo || true
                docker run -d --name cicd-demo -p 8081:80 cicd-demo
                '''
            }
        }
    }
}
